---
const items = [
  { href: '#services', label: 'Услуги' },
  { href: '#masters', label: 'Мастера' },
  { href: '#school', label: 'Школа' },
  { href: '#locations', label: 'Адреса' },
];
---
<nav class="nav">
  <div class="container-x nav__inner">
    <a href="#top" class="nav__logo" aria-label="Highbrow — на главную">
      <span class="nav__logo-mark">◒</span>
      <span class="nav__logo-word">
        high<em>b</em>row
      </span>
    </a>

    <ul class="nav__links">
      {items.map((i) => <li><a href={i.href}>{i.label}</a></li>)}
    </ul>

    <div class="nav__right">
      <a href="https://b692514.yclients.com" target="_blank" rel="noopener" class="nav__book">Записаться</a>
    </div>

    <button class="nav__burger" id="navBurger" aria-label="Меню">
      <span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="navMobile">
    {items.map((i) => <a href={i.href}>{i.label}</a>)}
    <a href="https://b692514.yclients.com" target="_blank" rel="noopener" class="nav__book nav__book--mobile">Записаться</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    backdrop-filter: blur(16px) saturate(1.1);
    background: rgba(245,241,232,0.72);
    border-bottom: 1px solid rgba(26,26,26,0.07);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 74px;
    gap: 24px;
  }
  .nav__logo {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .nav__logo-mark {
    font-size: 20px;
    color: var(--color-brand);
    line-height: 1;
  }
  .nav__logo-word em {
    font-style: italic;
    color: var(--color-brand);
    font-weight: 300;
  }

  .nav__links {
    display: flex;
    gap: 36px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__links a {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.5px;
    color: var(--color-text-soft);
    text-decoration: none;
    transition: color 0.25s;
    position: relative;
  }
  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0; right: 100%;
    bottom: -4px;
    height: 1px;
    background: var(--color-brand);
    transition: right 0.35s cubic-bezier(.22,1,.36,1);
  }
  .nav__links a:hover { color: var(--color-brand); }
  .nav__links a:hover::after { right: 0; }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .nav__book {
    display: inline-flex;
    align-items: center;
    padding: 11px 22px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    background: var(--color-brand);
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    transition: background 0.25s;
  }
  .nav__book:hover { background: var(--color-brand-dark); }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: transparent;
    border: 0;
    padding: 8px;
    cursor: pointer;
  }
  .nav__burger span {
    display: block;
    width: 22px; height: 1.5px;
    background: var(--color-text);
  }

  .nav__mobile {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: rgba(245,241,232,0.98);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    flex-direction: column;
    padding: 24px 28px 32px;
    gap: 4px;
    display: none;
  }
  .nav__mobile.open { display: flex; }
  .nav__mobile a {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--color-text);
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .nav__book--mobile {
    margin-top: 16px;
    justify-content: center;
    padding: 14px 0;
    font-family: var(--font-sans);
    font-size: 13px;
  }

  @media (max-width: 900px) {
    .nav__links, .nav__right { display: none; }
    .nav__burger { display: flex; }
  }
</style>

<script>
  const burger = document.getElementById('navBurger');
  const mobile = document.getElementById('navMobile');
  burger?.addEventListener('click', () => mobile?.classList.toggle('open'));
  mobile?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => mobile.classList.remove('open')));
</script>
