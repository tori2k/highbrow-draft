---
const base = import.meta.env.BASE_URL;

const features = [
  { title: 'Базовый курс', desc: 'Для начинающих бровистов. От архитектуры до работы с клиентом.' },
  { title: 'Повышение квалификации', desc: 'Для практикующих мастеров — новые техники, тренды и разбор сложных случаев.' },
  { title: 'Мини-группы и индивидуально', desc: 'До 3 человек в группе или один на один — на ваш выбор.' },
];
---
<section class="school" id="school">
  <div class="school__photo" data-parallax="0.08">
    <img src={`${base}media/master-working.jpg`} alt="Обучение в Highbrow" loading="lazy" />
  </div>

  <div class="container-x school__inner">
    <div class="school__content reveal-left">
      <div class="sec-tag">Школа Highbrow</div>
      <h2 class="display-h school__title">
        Учим делать<br/>
        <em>естественно</em>
      </h2>
      <p class="school__lead">
        Обучение для тех, кто хочет работать вдумчиво. Без&nbsp;трендов на&nbsp;шаблонные брови — только&nbsp;то, что идёт клиенту.
      </p>

      <ul class="school__features">
        {features.map((f, i) => (
          <li class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <div class="school__f-t">{f.title}</div>
            <div class="school__f-d">{f.desc}</div>
          </li>
        ))}
      </ul>

      <span class="magnet">
        <a href="https://t.me/highbrow_msk" target="_blank" rel="noopener" class="btn" data-hover>
          Узнать о курсах
          <span class="btn__arrow">→</span>
        </a>
      </span>
    </div>
  </div>
</section>

<style>
  .school {
    position: relative;
    padding: 200px 0;
    overflow: hidden;
    background: var(--color-text);
    color: var(--color-bg);
  }

  .school__photo {
    position: absolute;
    right: -5%;
    top: 10%;
    width: 52%;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 4px;
    opacity: 0.7;
  }
  .school__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2) contrast(1.05);
  }
  .school__photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--color-text) 0%, transparent 40%);
  }

  .school__inner { position: relative; z-index: 2; }
  .school__content {
    max-width: 640px;
  }

  .school .sec-tag { color: var(--color-brand); }
  .school .display-h { color: var(--color-bg); }
  .school .display-h em { color: var(--color-brand); }

  .school__title { margin: 0 0 32px; }
  .school__lead {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: rgba(245,241,232,0.75);
    margin: 0 0 48px;
    max-width: 520px;
  }

  .school__features {
    list-style: none;
    padding: 0;
    margin: 0 0 48px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .school__features li {
    padding: 22px 0;
    border-bottom: 1px solid rgba(245,241,232,0.12);
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 32px;
    align-items: baseline;
  }
  .school__features li:first-child { border-top: 1px solid rgba(245,241,232,0.12); }

  .school__f-t {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 20px;
    color: var(--color-bg);
  }
  .school__f-d {
    font-size: 14.5px;
    line-height: 1.65;
    color: rgba(245,241,232,0.65);
  }

  .school .btn {
    color: var(--color-bg);
    border-color: var(--color-bg);
  }
  .school .btn:hover {
    background: var(--color-bg);
    color: var(--color-text);
  }

  @media (max-width: 900px) {
    .school { padding: 90px 0; }
    .school__photo { width: 90%; opacity: 0.3; top: auto; bottom: -10%; right: -10%; }
    .school__features li { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
